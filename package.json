{
  "name": "@pague-co-uk/sms-gateway-queue-client",
  "version": "0.1.0",
  "description": "Framework-agnostic RabbitMQ client for the Pague SMS Gateway platform.",
  "license": "MIT",
  "author": "Pague UK",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pague-co-uk/sms-gateway-queue-client.git"
  },
  "bugs": {
    "url": "https://github.com/pague-co-uk/sms-gateway-queue-client/issues"
  },
  "homepage": "https://github.com/pague-co-uk/sms-gateway-queue-client#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepare": "npm run build"
  },
  "dependencies": {
    "amqplib": "^0.10.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/amqplib": "^0.10.7",
    "@types/node": "^24.3.0",
    "eslint": "^9.32.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0"
  }
}
